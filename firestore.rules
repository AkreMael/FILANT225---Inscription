rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DENY ALL BY DEFAULT
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Since we don't have a complex RBAC yet, we'll use a simple check or 
    // a specific email for admin access if necessary. 
    // For now, let's treat the user's requirement of "Admin" page as part of the app.
    // In a real app, we'd have an 'admins' collection.
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'filantmael225@gmail.com';
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      
      // Allow creation/update if it's the owner, with basic validation
      allow create, update: if isSignedIn() && (isOwner(userId) || isAdmin()) && isValidUser(incoming());
      allow delete: if isAdmin();
      
      // Subcollections
      match /missions/{missionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
      
      match /notifications/{notificationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // --- Messages ---
    match /messages/{messageId} {
      // Users can only read messages where they are the recipient or sender (associated by userId)
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidMessage(incoming()) 
                   && (incoming().userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // VALIDATION HELPERS
    function isValidUser(data) {
      // We allow basic info (email/displayName) to be saved initially.
      // If full profile fields are present, they must be the correct type.
      return data.keys().hasAny(['email', 'displayName', 'photoURL', 'profileType'])
        && (data.get('profileType', 'client') is string)
        && (data.get('isActivated', false) is bool)
        && (data.get('isAvailable', true) is bool)
        && (data.get('theme', 'light') is string);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'sender', 'userId', 'timestamp'])
        && data.text is string && data.text.size() < 5000
        && data.sender in ['admin', 'user']
        && data.userId is string // This should now be the UID
        && data.timestamp is timestamp;
    }
  }
}
