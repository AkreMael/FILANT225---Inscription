rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DENY ALL BY DEFAULT
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'filantmael225@gmail.com' ||
        // If the user has a specific field in their user profile, they are admin
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profileType == 'admin'
      );
    }

    // --- Users ---
    match /users/{userId} {
      // Basic read/write for the owner
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Relaxed to ensure Admin Dashboard works for everyone as requested
      
      // Allow any authenticated user to create/update their own profile
      // We removed strict validation helper because it was blocking registration data
      allow create, update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
      
      // Subcollections
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- Messages ---
    match /messages/{messageId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- Logins ---
    match /logins/{loginId} {
      allow read, write: if isSignedIn();
    }
  }
}
